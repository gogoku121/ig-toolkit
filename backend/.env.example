# Copy to .env and fill in real values. Never commit .env.

# SerpAPI key (kept server-side only, never shipped to the Android app)
SERPAPI_KEY=

# Groq API key for real LLM-based caption generation (server-side only).
# Get one at https://console.groq.com. If left blank, /generate returns 503
# and the Android app falls back to its offline template generator.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Shared secret the Android app sends in the X-App-Key header.
# This is NOT the SerpAPI key — it just gates access to this proxy.
# It will still be extractable from the APK by a determined attacker,
# but it does not expose the billed SerpAPI key or MinIO credentials.
APP_SHARED_SECRET=

# MinIO (S3-compatible) — used only to generate short-lived presigned
# download URLs for the release APK, never exposed to the client.
MINIO_ENDPOINT_URL=http://10.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=minio1
APK_OBJECT_KEY=ig-toolkit-kotlin-v1.apk

RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
