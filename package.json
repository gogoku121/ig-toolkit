{
  "name": "ig-toolkit",
  "version": "2.0.0",
  "description": "AI Instagram Business Toolkit",
  "type": "module",
  "scripts": {
    "start": "cd www && http-server -p 8080 -c-1",
    "dev": "cd www && http-server -p 8080 -c-1 --cors",
    "dev:android": "npx cap sync android && cd android && ./gradlew assembleDebug",
    "build:web": "rm -rf www && cp -r src www && cp index.html www/",
    "build:android": "npx cap sync android",
    "open:android": "npx cap open android"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
